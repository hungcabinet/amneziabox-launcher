      "label": "Israel-specific sites",
      "description": "Send Israel-focused traffic via main proxy selector.",
      "rule_set": [
        { "tag": "israel-sites", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-il.srs"}
      ],
      "rule": { "rule_set": "israel-sites", "outbound": "proxy-out" }
