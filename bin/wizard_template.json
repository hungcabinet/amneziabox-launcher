      "label": "Games direct",
      "description": "Send gaming rule set traffic directly for lower latency.",
      "default": true,
      "rule_set": [
        { "tag": "games", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-games.srs"}
